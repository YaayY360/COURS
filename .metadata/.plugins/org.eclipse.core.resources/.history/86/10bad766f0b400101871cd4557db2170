int getMinPosition(int * array, int * toBeIgnored, int size) {
	int min=array[0];
	int imin=0;
	for (int i=0; i<size; i++) {
		if (toBeIgnored[i]!=1) {
			if (array[i]<min){
				imin=i;
				min=array[i];
			}
		}
	}
	return imin;
}


