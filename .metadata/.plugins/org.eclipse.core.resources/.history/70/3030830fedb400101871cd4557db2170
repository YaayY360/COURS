#define ARRAY_SIZE 15

int arrayTest[ARRAY_SIZE]={0, 1, -3, 10, -1, 0, 0, 0, 0, 12, 1024, 10, 45, 6, 4};


void setup(){
	printf("le système a démarré");
}

void loop(){
	int index;
	index=getMinPosition(arrayTest,ARRAY_SIZE);
	printf("First min at : %d \n\r", index);
}

int getMinPosition(array, size) {
	int min=array[0];
	int imin=0;
	for (int i=0; i<size; i++) {
		if (array[i]<min){
			imin=i;
			min=array[i];
		}
	}
	return imin;
}
